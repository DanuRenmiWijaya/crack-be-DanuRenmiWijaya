generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      =  env("DATABASE_URL_PROD")
}

model Patient {
  id        String   @id @default(uuid())
  nik       String   @unique
  name      String
  gender    String
  birthDate DateTime
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  records        MedicalRecord[]
  appointments Appointment[]
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("ADMIN") // ADMIN atau DOCTOR
  createdAt DateTime @default(now())
  doctorRecords  MedicalRecord[]
}

model MedicalRecord {
  id             String   @id @default(uuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         User     @relation(fields: [doctorId], references: [id])
  complaint      String   
  diagnosis      String   
  physicalExam   String?  
  treatment      String?  
  prescription   String?  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Appointment {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visitDate   DateTime
  department  String   
  status      String   @default("PENDING") 
  queueNumber Int?
  createdAt   DateTime @default(now())
}
