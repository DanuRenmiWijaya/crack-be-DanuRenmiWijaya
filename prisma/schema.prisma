generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String   @id @default(uuid())
  nik       String   @unique
  name      String
  gender    String
  birthDate DateTime
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  records        MedicalRecord[]
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("ADMIN") // ADMIN atau DOCTOR
  createdAt DateTime @default(now())
  doctorRecords  MedicalRecord[]
}

model MedicalRecord {
  id             String   @id @default(uuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         User     @relation(fields: [doctorId], references: [id])
  complaint      String   
  diagnosis      String   
  physicalExam   String?  
  treatment      String?  
  prescription   String?  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}